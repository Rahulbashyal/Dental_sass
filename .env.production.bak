APP_NAME="Dental Care SaaS"
APP_ENV=production
APP_KEY=base64:cEtB0pf2GgHSLxNEVl5/WMJ5Q7mWvjItPsUyGji/aGE=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://yourdomain.com

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dental_care_prod
DB_USERNAME=dental_user
DB_PASSWORD=your_secure_password

# Cache & Performance
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=redis

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Security Settings
SESSION_LIFETIME=480
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=your-smtp-host
MAIL_PORT=587
MAIL_USERNAME=your-email
MAIL_PASSWORD=your-password
MAIL_ENCRYPTION=tls

# Logging
LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error